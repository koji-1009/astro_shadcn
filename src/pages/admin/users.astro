---
import UserTable from "@/features/user/components/UserTable.astro";
import Pagination from "@/shared/components/Pagination.astro";
import AdminLayout from "@/shared/layout/AdminLayout.astro";
import { getUsers } from "@/features/user";

const PER_PAGE = 10;
const page = Math.max(1, Number(Astro.url.searchParams.get("page")) || 1);
const allUsers = getUsers();
const totalPages = Math.max(1, Math.ceil(allUsers.length / PER_PAGE));
const currentPage = Math.min(page, totalPages);
const users = allUsers.slice(
	(currentPage - 1) * PER_PAGE,
	currentPage * PER_PAGE,
);
---
<AdminLayout title="ユーザー管理 - お弁当管理">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">ユーザー管理</h1>
    <p class="text-sm text-muted-foreground mt-1">登録ユーザー一覧（zero JS テーブル）</p>
  </div>
  <UserTable users={users} />
  <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/admin/users" />
</AdminLayout>
