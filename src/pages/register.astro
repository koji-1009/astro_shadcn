---
import { UserRegistrationForm } from "@/features/user/components/UserRegistrationForm";
import UserLayout from "@/shared/layout/UserLayout.astro";
---
<UserLayout title="ユーザー登録">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">ユーザー登録</h1>
    <p class="text-sm text-muted-foreground mt-1">
      部署を選択すると、利用可能なロールとフロアが動的に変わります（React Island）
    </p>
  </div>
  <UserRegistrationForm client:load />
</UserLayout>
