---
import { getMenusByCategory } from "@/features/menu";
import MenuGrid from "@/features/menu/components/MenuGrid.astro";
import UserLayout from "@/shared/layout/UserLayout.astro";
import { CATEGORY_LABELS, menuCategorySchema } from "@/shared/types/categories";

const parsed = menuCategorySchema.safeParse(Astro.params.category);

if (!parsed.success) {
	return Astro.redirect("/");
}

const category = parsed.data;
const label = CATEGORY_LABELS[category];
const items = getMenusByCategory(category);
---
<UserLayout title={label}>
  <h1 class="text-xl font-bold mb-4">{label}</h1>
  <MenuGrid items={items} />
</UserLayout>
