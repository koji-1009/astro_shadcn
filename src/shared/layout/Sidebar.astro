---
interface Props {
	currentPath: string;
}
const { currentPath } = Astro.props;

const links = [
	{ href: "/admin/", label: "ダッシュボード", icon: "📊" },
	{ href: "/admin/menu/lunch/", label: "お昼弁当", icon: "🍱" },
	{ href: "/admin/menu/snack/", label: "おやつ", icon: "🍩" },
	{ href: "/admin/orders/", label: "注文一覧", icon: "📋" },
	{ href: "/admin/notices/", label: "お知らせ", icon: "📢" },
	{ href: "/admin/users/", label: "ユーザー管理", icon: "👤" },
];

function isActive(linkHref: string, current: string): boolean {
	const normalizedCurrent = current.endsWith("/") ? current : `${current}/`;
	return normalizedCurrent === linkHref;
}
---
<nav aria-label="管理メニュー" class="py-4">
  <ul class="space-y-1 px-3">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={[
            "flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors",
            isActive(link.href, currentPath)
              ? "bg-accent text-accent-foreground"
              : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
          ]}
          aria-current={isActive(link.href, currentPath) ? "page" : undefined}
        >
          <span class="text-base">{link.icon}</span>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
