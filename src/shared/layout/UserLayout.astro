---
import { ViewTransitions } from "astro:transitions";
import "@/styles/globals.css";
import TopBar from "./TopBar.astro";
import UserNav from "./UserNav.astro";

interface Props {
	title?: string;
}

const { title = "お弁当注文" } = Astro.props;
---
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content="社内お弁当注文システム — Astro SSR デモ" />
  <ViewTransitions />
</head>
<body class="min-h-screen">
  <TopBar role={Astro.locals.role} transition:animate="none" />
  <UserNav currentPath={Astro.url.pathname} transition:animate="none" />
  <main class="max-w-5xl mx-auto p-4 md:p-6" transition:animate="fade">
    <slot />
  </main>
</body>
</html>
