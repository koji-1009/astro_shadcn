---
import { ViewTransitions } from "astro:transitions";
import "@/styles/globals.css";
import Sidebar from "./Sidebar.astro";
import TopBar from "./TopBar.astro";

interface Props {
	title?: string;
}

const { title = "お弁当管理" } = Astro.props;
---
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content="お弁当注文システム管理画面 — Astro SSR デモ" />
  <ViewTransitions />
</head>
<body class="min-h-screen">
  <TopBar role={Astro.locals.role} transition:animate="none" />
  <div class="md:grid md:grid-cols-[var(--sidebar-width)_1fr] h-[calc(100vh-var(--topbar-height))]" transition:animate="none">
    <aside class="hidden md:block border-r bg-sidebar overflow-y-auto">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>
    <!-- Mobile nav -->
    <details class="md:hidden border-b bg-sidebar">
      <summary class="px-4 py-3 text-sm font-medium cursor-pointer">メニュー</summary>
      <Sidebar currentPath={Astro.url.pathname} />
    </details>
    <main class="overflow-y-auto p-4 md:p-6" transition:animate="fade">
      <slot />
    </main>
  </div>
</body>
</html>
