---
import type { Role } from "@/shared/types";

interface Props {
	role: Role;
}

const { role } = Astro.props;
const label = role === "admin" ? "ユーザーに切り替え" : "管理者に切り替え";
---
<button
  type="button"
  id="role-switcher"
  class="text-sm text-muted-foreground hover:text-foreground transition-colors cursor-pointer"
>
  {label}
</button>

<script>
  function setupRoleSwitcher() {
    document.getElementById("role-switcher")?.addEventListener("click", async () => {
      try {
        const res = await fetch("/api/switch-role", { method: "POST" });
        if (!res.ok) throw new Error();
        const data = await res.json();
        window.location.href = data.redirectTo;
      } catch {
        const btn = document.getElementById("role-switcher");
        if (btn) btn.textContent = "切り替えに失敗しました";
      }
    });
  }
  document.addEventListener("astro:page-load", setupRoleSwitcher);
</script>
