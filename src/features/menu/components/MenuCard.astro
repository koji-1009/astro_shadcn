---
import { CATEGORY_LABELS } from "@/shared/types/categories";
import type { MenuItem } from "../types";

interface Props {
	item: MenuItem;
}

const { item } = Astro.props;
---
<a
  href={`/menu/item/${item.id}/`}
  class:list={[
    "block rounded-lg border bg-card p-4 transition-shadow hover:shadow-md",
    !item.available && "opacity-50 pointer-events-none",
  ]}
>
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-semibold">{item.name}</h3>
    {!item.available && (
      <span class="text-xs bg-muted text-muted-foreground px-2 py-0.5 rounded-full shrink-0">
        売り切れ
      </span>
    )}
  </div>
  <p class="text-sm text-muted-foreground mt-1">{CATEGORY_LABELS[item.category]}</p>
  <p class="text-lg font-bold mt-2">&yen;{item.price.toLocaleString()}</p>
  {item.options.length > 0 && (
    <p class="text-xs text-muted-foreground mt-1">
      オプション: {item.options.length}種類
    </p>
  )}
</a>
