---
import type { Notice } from "../types";

interface Props {
	notices: Notice[];
}

const { notices } = Astro.props;
const sorted = [...notices].sort((a, b) => {
	if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
	return b.publishedAt.localeCompare(a.publishedAt);
});
---
<div class="space-y-4">
  {sorted.map(notice => (
    <article class="border rounded-lg p-4">
      <div class="flex items-start gap-2">
        {notice.pinned && (
          <span class="text-xs bg-primary text-primary-foreground px-2 py-0.5 rounded-full shrink-0">
            固定
          </span>
        )}
        <div class="flex-1">
          <h3 class="font-semibold">{notice.title}</h3>
          <time class="text-xs text-muted-foreground">{notice.publishedAt}</time>
          <p class="text-sm mt-2 text-muted-foreground">{notice.body}</p>
        </div>
      </div>
    </article>
  ))}
</div>
