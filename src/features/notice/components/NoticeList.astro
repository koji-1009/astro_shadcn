---
import { getNotices } from "@/features/notice";
import NoticeEditPanel from "./NoticeEditPanel";

const sortedNotices = [...getNotices()].sort((a, b) => {
	if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
	return b.publishedAt.localeCompare(a.publishedAt);
});
---
<div class="space-y-4">
  {sortedNotices.map(notice => (
    <div class="rounded-lg border bg-card p-5 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            {notice.pinned && (
              <span class="inline-flex items-center rounded-full bg-blue-50 border border-blue-200 px-2 py-0.5 text-xs font-semibold text-blue-700">
                固定
              </span>
            )}
            <h3 class="font-semibold">{notice.title}</h3>
          </div>
          <p class="text-sm text-muted-foreground mt-1">{notice.body}</p>
          <p class="text-xs text-muted-foreground mt-2">{notice.publishedAt}</p>
        </div>
        <NoticeEditPanel mode="edit" notice={notice} client:idle />
      </div>
    </div>
  ))}
</div>
